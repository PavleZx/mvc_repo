
@model mvc_app.Models.Item
@{
    ViewData["Title"] = "Edit Item";
}

<h1>Edit Item @Model</h1>


<form asp-action="Edit" method="post">
    <div class="form-group">
        <label asp-for="Name">Name</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Price">Price</label>
        <input asp-for="Price" class="form-control" />
    </div>
    <div class="form-group">
        <label>Serial Number</label>
        <input name="SerialNumberName" class="form-control " value="@ViewBag.SerialNumberName" />
    </div>
    <div class="form-group">
        <label asp-for="CategoryId">Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
    </div>
    <button type ="submit" class="btn btn-primary">Submit</button>


</form>

